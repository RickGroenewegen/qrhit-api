# Test environment overrides. Loaded by test/setup.ts AFTER .env, with
# override:true — values here win. Contains NO real secrets: database and
# Redis hosts/credentials are inherited from your local .env; only the
# database NAME is swapped to the dedicated test database (see
# TEST_DATABASE_NAME below) and Redis moves to its own db index.

ENVIRONMENT=test
MAIN_SERVER=false
RUN_QUEUE_WORKERS=false

# test/setup.ts rewrites DATABASE_URL's database name to this value.
# Safety: helpers refuse to truncate any database whose name doesn't end
# in "_test".
TEST_DATABASE_NAME=qrhit_test

# Redis: same server as .env, but isolated keyspace (src/cache.ts honors
# REDIS_DB; defaults to 0 outside tests).
REDIS_DB=9

JWT_SECRET=test-jwt-secret-not-for-production
PLAYLIST_SECRET=test-playlist-secret

# Writable scratch dirs (created by test/setup.ts, gitignored)
PUBLIC_DIR=./test/.tmp/public
PRIVATE_DIR=./test/.tmp/private
ASSETS_DIR=./test/.tmp/assets
APP_ROOT=./src

FRONTEND_URI=http://localhost:4200
API_URI=http://localhost:3004

# Dummy keys: anything that would hit a paid/external API must be mocked;
# these exist only so module-level constructors don't throw.
MOLLIE_API_KEY=test_dummy
MOLLIE_API_KEY_TEST=test_dummy
OPENAI_API_KEY=test-dummy
FROM_EMAIL=test@qrsong.io
INFO_EMAIL=test@qrsong.io
BCC_EMAIL=
PUSHOVER_APP_KEY=test-dummy
PUSHOVER_USER_KEY=test-dummy
