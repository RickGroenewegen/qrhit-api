<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />

		<title><%= process.env['PRODUCT_NAME'] %> - <%= translations.invoice %></title>

		<!-- Favicon -->
		<link rel="icon" href="./images/favicon.png" type="image/x-icon" />

		<!-- Invoice styling -->
		<style>
			@media print {
				@page {
					size: A4;
					margin: 0;
				}
				body {
					-webkit-print-color-adjust: exact !important;
					print-color-adjust: exact !important;
				}
			}
			
			body {
				font-family: 'Helvetica Neue', 'Helvetica', Helvetica, Arial, sans-serif;
				text-align: center;
				color: #777;
				margin: 0;
				padding: 0;
			}

			body h1 {
				font-weight: 300;
				margin-bottom: 0px;
				padding-bottom: 0px;
				color: #000;
			}

			body h3 {
				font-weight: 300;
				margin-top: 10px;
				margin-bottom: 20px;
				font-style: italic;
				color: #555;
			}

			body a {
				color: #06f;
			}

			.invoice-box {
				width: 210mm;
				height: 297mm;
				margin: 0 auto;
				padding: 30px;
				box-sizing: border-box;
				border: 1px solid #eee;
				box-shadow: 0 0 10px rgba(0, 0, 0, 0.15);
				font-size: 12px;
				line-height: 18px;
				font-family: 'Helvetica Neue', 'Helvetica', Helvetica, Arial, sans-serif;
				color: #555;
				background-color: white;
			}

			.invoice-box table {
				width: 100%;
				line-height: inherit;
				text-align: left;
				border-collapse: collapse;
			}

			.invoice-box table td {
				padding: 5px;
				vertical-align: top;
			}

			.invoice-box table tr td:nth-child(n+2) {
				text-align: right;
			}

			.invoice-box table tr.top table td {
				padding-bottom: 20px;
			}

			.invoice-box table tr.top table td.title {
				font-size: 35px;
				line-height: 35px;
				color: #333;
			}

			.invoice-box table tr.information table td {
				padding-bottom: 40px;
			}

			.invoice-box table tr.heading td {
				background: #eee;
				border-bottom: 1px solid #ddd;
				font-weight: bold;
			}

			.invoice-box table tr.details td {
				padding-bottom: 20px;
			}

			.invoice-box table tr.item td {
				border-bottom: 1px solid #eee;
			}

			.invoice-box table tr.item.last td {
				border-bottom: none;
			}

			.invoice-box table tr.total  {
				border-top: 2px solid #eee;
				font-weight: bold;
			}

			@media only screen and (max-width: 600px) {
				.invoice-box table tr.top table td {
					width: 100%;
					display: block;
					text-align: center;
				}

				.invoice-box table tr.information table td {
					width: 100%;
					display: block;
					text-align: center;
				}
			}
		</style>
	</head>

	<body>
		
		<div class="invoice-box">
            <!-- (<%= JSON.stringify(payment, null, 2) %>) -->
			<table border="0">
				<tr class="top">
					<td colspan="7">
						<table>
							<tr>
								<td class="title">
									<img src="<%= process.env['API_URI'] %>/assets/images/logo.png" alt="Company logo" style="width: 100%; max-width: 200px" />
								</td>
								<td>
									<%= translations.invoiceNumber %>: <%= payment.orderId %><br />
									<%= translations.invoiceDate %>: <%= dateFormatter.format(payment.createdAt) %><br />
                                    <%= translations.paidInFull %><br />
								</td>
							</tr>
						</table>
					</td>
				</tr>

				<tr class="information">
					<td colspan="7">
						<table>
							<tr>
								<td>
									<%= process.env['PRODUCT_NAME'] %><br />
									<%= process.env['PRODUCT_POSTBOX'] %><br />
									<%= process.env['PRODUCT_ADDRESS'] %><br />
									<%= process.env['PRODUCT_ZIPCODE'] %> <%= process.env['PRODUCT_CITY'] %><br/>
                                    <%= countries[process.env['PRODUCT_COUNTRY']] %>
								</td>
								<td>
									<% if (payment.isBusinessOrder && payment.companyName) { %>
										<strong><%= payment.companyName %></strong><br />
										<%= payment.fullname %><br />
									<% } else { %>
										<%= payment.fullname %><br />
									<% } %>
									<%= payment.invoiceAddress || payment.address %> <%= payment.invoiceHousenumber || payment.housenumber %><br/>
                                    <%= payment.invoiceZipcode || payment.zipcode %> <%= payment.invoiceCity || payment.city %><br/>
									<%= countries[payment.invoiceCountrycode || payment.countrycode] %><br/>
									<% if (payment.isBusinessOrder && payment.vatId) { %>
										<%= translations.vatId %>: <%= payment.vatId %><br/>
									<% } %>
								</td>
							</tr>
						</table>
					</td>
				</tr>

				<tr class="heading">
					<td><%= translations.method %></td>
					<td colspan="6"></td>
				</tr>

				<tr class="details">
					<td><%= translations[payment.paymentMethod] %></td>
					<td colspan="6"></td>
				</tr>

				<tr class="heading">
					<td><%= translations.product %></td>
					<td style="text-align:right;"><%= translations.quantity %></td>
					<td style="text-align:right;"><%= translations.unitPriceExclVAT %></td>
					<td style="text-align:right;"><%= translations.totalExclVAT %></td>
					<td style="text-align:right;"><%= translations.taxRate %></td>
					<td style="text-align:right;"><%= translations.vatAmount %></td>
					<td style="text-align:right;"><%= translations.totalInclVAT %></td>
				</tr>

				<% playlists.forEach(function(playlist) {
					const totalExclVAT = playlist.price - playlist.priceVAT;
					const unitPriceExclVAT = totalExclVAT / playlist.amount;
				%>
					<tr class="item">
						<td><%= playlist.productType === 'giftcard' ? translations.giftcard : playlist.name %></td>
						<td style="text-align:right;"><%= playlist.amount %></td>
						<td style="text-align:right;"><%= moneyFormatter.format(displayRate *unitPriceExclVAT) %></td>
						<td style="text-align:right;"><%= moneyFormatter.format(displayRate *totalExclVAT) %></td>
						<td style="text-align:right;"><%= payment.reverseCharge ? '—' : (payment.taxRate + '%') %></td>
						<td style="text-align:right;"><%= payment.reverseCharge ? '—' : moneyFormatter.format(displayRate *playlist.priceVAT) %></td>
						<td style="text-align:right;"><%= moneyFormatter.format(displayRate *playlist.price) %></td>
					</tr>
				<% }); %>

				<% // Gift box and QRGames are VAT-inclusive add-ons charged at the
				   // product tax rate, folded into the order total. Show them as
				   // their own lines so the itemisation reconciles with the total.
				   const addonRate = payment.taxRate || 0;
				%>

				<% if (payment.boxFee && payment.boxFee > 0) {
					let boxQty = 0;
					playlists.forEach(function(pl) {
						if (pl.boxEnabled) { boxQty += (pl.boxQuantity || 0) * (pl.amount || 1); }
					});
					if (boxQty < 1) { boxQty = 1; }
					const boxExclVAT = payment.reverseCharge ? payment.boxFee : payment.boxFee / (1 + addonRate / 100);
					const boxVAT = payment.boxFee - boxExclVAT;
				%>
					<tr class="item">
						<td><%= translations.giftBox || 'Gift box' %></td>
						<td style="text-align:right;"><%= boxQty %></td>
						<td style="text-align:right;"><%= moneyFormatter.format(displayRate *(boxExclVAT / boxQty)) %></td>
						<td style="text-align:right;"><%= moneyFormatter.format(displayRate *boxExclVAT) %></td>
						<td style="text-align:right;"><%= payment.reverseCharge ? '—' : (payment.taxRate + '%') %></td>
						<td style="text-align:right;"><%= payment.reverseCharge ? '—' : moneyFormatter.format(displayRate *boxVAT) %></td>
						<td style="text-align:right;"><%= moneyFormatter.format(displayRate *payment.boxFee) %></td>
					</tr>
				<% } %>

				<% if (payment.gamesFee && payment.gamesFee > 0) {
					let gamesQty = 0;
					playlists.forEach(function(pl) {
						if (pl.gamesEnabled) { gamesQty += 1; }
					});
					if (gamesQty < 1) { gamesQty = 1; }
					const gamesExclVAT = payment.reverseCharge ? payment.gamesFee : payment.gamesFee / (1 + addonRate / 100);
					const gamesVAT = payment.gamesFee - gamesExclVAT;
				%>
					<tr class="item">
						<td><%= translations.qrGames || 'QRGames' %></td>
						<td style="text-align:right;"><%= gamesQty %></td>
						<td style="text-align:right;"><%= moneyFormatter.format(displayRate *(gamesExclVAT / gamesQty)) %></td>
						<td style="text-align:right;"><%= moneyFormatter.format(displayRate *gamesExclVAT) %></td>
						<td style="text-align:right;"><%= payment.reverseCharge ? '—' : (payment.taxRate + '%') %></td>
						<td style="text-align:right;"><%= payment.reverseCharge ? '—' : moneyFormatter.format(displayRate *gamesVAT) %></td>
						<td style="text-align:right;"><%= moneyFormatter.format(displayRate *payment.gamesFee) %></td>
					</tr>
				<% } %>

				<% if (orderType != 'digital') {
					const shippingExclVAT = payment.shipping - payment.shippingVATPrice;
				%>
					<tr class="item">
						<td><%= translations.shippingAndHandling %></td>
						<td style="text-align:right;">1</td>
						<td style="text-align:right;"><%= moneyFormatter.format(displayRate *shippingExclVAT) %></td>
						<td style="text-align:right;"><%= moneyFormatter.format(displayRate *shippingExclVAT) %></td>
						<td style="text-align:right;"><%= payment.reverseCharge ? '—' : (payment.taxRateShipping + '%') %></td>
						<td style="text-align:right;"><%= payment.reverseCharge ? '—' : moneyFormatter.format(displayRate *payment.shippingVATPrice) %></td>
						<td style="text-align:right;"><%= moneyFormatter.format(displayRate *payment.shipping) %></td>
					</tr>
				<% } %>

				<!-- Subtotal and VAT breakdown -->
				<% const subtotalExclVAT = payment.totalPrice - payment.totalVATPrice; %>

				<tr style="border-top: 2px solid #eee;">
					<td colspan="6" style="text-align:right; padding-top: 20px;"><strong><%= translations.subtotalExclVAT %>:</strong></td>
					<td style="text-align:right; padding-top: 20px;"><strong><%= moneyFormatter.format(displayRate *subtotalExclVAT) %></strong></td>
				</tr>

				<% if (payment.reverseCharge) { %>
				<tr>
					<td colspan="6" style="text-align:right; color: #1e3a8a;"><strong><%= translations.reverseChargeLine || 'VAT reverse charged (0%)' %>:</strong></td>
					<td style="text-align:right; color: #1e3a8a;"><strong><%= moneyFormatter.format(0) %></strong></td>
				</tr>
				<% } else {
					// Box and QRGames are taxed at the product rate; include their
					// embedded VAT in the product VAT line so the breakdown sums to
					// the (corrected) total VAT.
					const summaryAddonsGross = (payment.boxFee || 0) + (payment.gamesFee || 0);
					const summaryAddonsExclVAT = summaryAddonsGross / (1 + (payment.taxRate || 0) / 100);
					const summaryAddonsVAT = summaryAddonsGross - summaryAddonsExclVAT;
					const productBaseExclVAT = payment.productPriceWithoutTax + summaryAddonsExclVAT;
					const productVATTotal = payment.productVATPrice + summaryAddonsVAT;
				%>
					<% if (productVATTotal > 0) { %>
					<tr>
						<td colspan="6" style="text-align:right;"><%= translations.vat %> <%= payment.taxRate %>% <%= translations.over %> <%= moneyFormatter.format(displayRate *productBaseExclVAT) %>:</td>
						<td style="text-align:right;"><%= moneyFormatter.format(displayRate *productVATTotal) %></td>
					</tr>
					<% } %>

					<% if (orderType != 'digital' && payment.shippingVATPrice > 0) { %>
					<tr>
						<td colspan="6" style="text-align:right;"><%= translations.vat %> <%= payment.taxRateShipping %>% <%= translations.over %> <%= moneyFormatter.format(displayRate *payment.shippingPriceWithoutTax) %> (<%= translations.shipping %>):</td>
						<td style="text-align:right;"><%= moneyFormatter.format(displayRate *payment.shippingVATPrice) %></td>
					</tr>
					<% } %>
				<% } %>

				<% if (payment.DiscountCodedUses && payment.DiscountCodedUses.length > 0) { %>
				<% const totalDiscount = payment.DiscountCodedUses.reduce((sum, use) => sum + use.amount, 0); %>
				<tr>
					<td colspan="6" style="text-align:right; color: #2e7d32;"><%= translations.discount %>:</td>
					<td style="text-align:right; color: #2e7d32;">-<%= moneyFormatter.format(displayRate *totalDiscount) %></td>
				</tr>
				<% } %>

				<tr class="total" style="border-top: 2px solid #333;">
					<td colspan="6" style="text-align:right; padding-top: 10px;"><strong><%= translations.totalInclVAT %>:</strong></td>
					<td style="text-align:right; padding-top: 10px;"><strong><%= moneyFormatter.format(presentmentTotal) %></strong></td>
				</tr>

				<% if (payment.reverseCharge) { %>
				<tr>
					<td colspan="7" style="padding-top: 20px;">
						<div style="border: 1px solid #1e3a8a; background: #eff6ff; padding: 12px; border-radius: 4px;">
							<div style="font-weight: bold; color: #1e3a8a; margin-bottom: 4px;">
								<%= translations.reverseChargeHeading || 'VAT reverse charged' %>
							</div>
							<div style="font-size: 11px; color: #1e3a8a; line-height: 1.5;">
								<%= translations.reverseChargeExplanation || 'VAT is reverse charged to the recipient in accordance with Article 196 of Council Directive 2006/112/EC. The recipient is liable to self-account for VAT under the local reverse-charge procedure.' %>
								<% if (payment.vatIdChecked) { %>
									<br/><%= translations.vatIdVerified || 'VAT ID verified via VIES' %>: <strong><%= payment.vatIdChecked %></strong>
								<% } %>
							</div>
						</div>
					</td>
				</tr>
				<% } %>

				<% if (invoiceCurrency !== 'EUR') { %>
				<tr>
					<td colspan="7" style="text-align:right; padding-top: 15px; font-size: 10px; color: #888;">
						<%= translations.eurEquivalent || 'EUR equivalent' %>: <%= euroFormatter.format(payment.totalPrice) %>
						(<%= translations.exchangeRate || 'rate' %>: 1 EUR = <%= invoiceRate.toFixed(4) %> <%= invoiceCurrency %>)
					</td>
				</tr>
				<% } %>
			</table>
		</div>
	</body>
</html>
