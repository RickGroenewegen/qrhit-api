<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Box Insert - QRSong!</title>
<style>
    @media print {
        @page {
            size: 120mm 120mm;
            margin: 0;
        }
        body {
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }
        .page {
            page-break-after: always;
        }
        .page:last-child {
            page-break-after: auto;
        }
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        width: 120mm;
        font-family: Arial, sans-serif;
    }

    .page {
        width: 120mm;
        height: 120mm;
        position: relative;
        overflow: hidden;
    }

    .background {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    .background-image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .background-color {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    .content {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        z-index: 1;
    }

    .logo-image {
        max-width: 60mm;
        max-height: 40mm;
        object-fit: contain;
    }

    .emoji {
        font-size: 48px;
        margin-top: 8px;
    }

    .front-title {
        position: absolute;
        transform: translate(-50%, -50%);
        text-align: center;
        line-height: 1;
        white-space: nowrap;
    }

    .back-text {
        padding: 15mm;
        text-align: center;
        font-size: <%= parseFloat(php.boxBackSelectedFontSize || '14') * 1.47 %>px;
        font-family: <%= php.boxBackSelectedFont || 'Arial, sans-serif' %>;
        line-height: 1.5;
        word-wrap: break-word;
        white-space: pre-wrap;
    }
</style>
<%
// Font embedding for box text (back personal message + front text title)
let boxFontStyles = '';
const fontsToEmbed = [];
[php.boxBackSelectedFont, php.boxFrontTitleFont].forEach(function (f) {
    if (f && f !== 'Arial, sans-serif' && fontsToEmbed.indexOf(f) === -1) {
        fontsToEmbed.push(f);
    }
});
fontsToEmbed.forEach(function (f) {
    let fontName = f.split(',')[0].trim().replace(/["']/g, '');
    let googleFontName = fontName.replace(/ /g, '+');
    let weights = typeof getGoogleFontWeights === 'function' ? getGoogleFontWeights(f) : '400;700';
    boxFontStyles += `
    <style>
        @import url('https://fonts.googleapis.com/css2?family=${googleFontName}:wght@${weights}&display=swap');
    </style>
    <link href="https://fonts.googleapis.com/css2?family=${googleFontName}:wght@${weights}&display=swap" rel="stylesheet">
    `;
});
if (fontsToEmbed.length) {
    boxFontStyles = `
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    ` + boxFontStyles;
}
%>
<%- boxFontStyles %>
</head>
<body>
<%
// Repeat the front+back pair `boxQuantity` times so the rendered PDF
// already contains every physical insert card the customer ordered.
const insertCount = Math.max(1, php.boxQuantity || 1);
for (let i = 0; i < insertCount; i++) {
%>
<!-- Insert <%= i + 1 %> of <%= insertCount %> — Front side (visible through window) -->
<div class="page">
    <div class="background">
        <% if (php.boxFrontBackgroundType === 'image' && php.boxFrontBackground) { %>
            <img class="background-image" src="<%= process.env['API_URI'] %>/public/background/<%= php.boxFrontBackground %>"
                 style="opacity: <%= (php.boxFrontOpacity || 100) / 100 %>;" />
        <% } %>
        <% if (php.boxFrontBackgroundType === 'solid' || !php.boxFrontBackground) { %>
            <% if (php.boxFrontUseFrontGradient) { %>
                <div class="background-color" style="background: linear-gradient(<%= php.boxFrontGradientDegrees || 180 %>deg, <%= php.boxFrontBackgroundColor || '#ffffff' %> <%= php.boxFrontGradientPosition || 50 %>%, <%= php.boxFrontGradientColor || '#ffffff' %> 100%);"></div>
            <% } else { %>
                <div class="background-color" style="background-color: <%= php.boxFrontBackgroundColor || '#ffffff' %>;"></div>
            <% } %>
        <% } %>
        <% if (php.boxFrontBackgroundType === 'image' && php.boxFrontBackground && php.boxFrontUseFrontGradient) { %>
            <div class="background-color" style="background: linear-gradient(<%= php.boxFrontGradientDegrees || 180 %>deg, <%= php.boxFrontBackgroundColor || '#ffffff' %> <%= php.boxFrontGradientPosition || 50 %>%, <%= php.boxFrontGradientColor || '#ffffff' %> 100%); opacity: 0.5;"></div>
        <% } %>
    </div>
    <div class="content">
        <% if ((php.boxFrontTitleType || 'logo') === 'text' && php.boxFrontTitleText) { %>
            <%
            // Build the styled text title for the front of the box.
            let titleStyle = 'left: ' + (php.boxFrontTitlePositionX != null ? php.boxFrontTitlePositionX : 50) + '%;'
                + ' top: ' + (php.boxFrontTitlePositionY != null ? php.boxFrontTitlePositionY : 50) + '%;'
                + ' font-family: ' + (php.boxFrontTitleFont || 'Arial, sans-serif') + ';'
                + ' font-size: ' + ((php.boxFrontTitleFontSize || 32) * 1.47) + 'px;'
                + ' color: ' + (php.boxFrontTitleColor || '#ffffff') + ';';
            if (php.boxFrontTitleStrokeWidth && php.boxFrontTitleStrokeWidth > 0) {
                titleStyle += ' -webkit-text-stroke: ' + php.boxFrontTitleStrokeWidth + 'px ' + (php.boxFrontTitleStrokeColor || '#000000') + ';';
            }
            if (php.boxFrontTitleShadowEnabled) {
                titleStyle += ' text-shadow: ' + (php.boxFrontTitleShadowOffsetX != null ? php.boxFrontTitleShadowOffsetX : 2) + 'px '
                    + (php.boxFrontTitleShadowOffsetY != null ? php.boxFrontTitleShadowOffsetY : 2) + 'px '
                    + (php.boxFrontTitleShadowBlur != null ? php.boxFrontTitleShadowBlur : 4) + 'px '
                    + (php.boxFrontTitleShadowColor || '#000000') + ';';
            }
            %>
            <div class="front-title" style="<%= titleStyle %>"><%= php.boxFrontTitleText %></div>
        <% } else if (php.boxFrontLogo) { %>
            <img class="logo-image" src="<%= process.env['API_URI'] %>/public/logo/<%= php.boxFrontLogo %>"
                 style="max-width: <%= (php.boxFrontLogoScale || 50) %>%; max-height: <%= (php.boxFrontLogoScale || 50) %>%; position: absolute; left: <%= (php.boxFrontLogoPositionX || 50) %>%; top: <%= (php.boxFrontLogoPositionY || 50) %>%; transform: translate(-50%, -50%); object-fit: contain;" />
        <% } %>
        <% if (php.boxFrontEmoji) { %>
            <div class="emoji"><%= php.boxFrontEmoji %></div>
        <% } %>
    </div>
</div>

<!-- Insert <%= i + 1 %> of <%= insertCount %> — Back side -->
<div class="page">
    <div class="background">
        <% if (php.boxBackBackgroundType === 'image' && php.boxBackBackground) { %>
            <img class="background-image" src="<%= process.env['API_URI'] %>/public/background/<%= php.boxBackBackground %>"
                 style="opacity: <%= (php.boxBackOpacity || 50) / 100 %>;" />
        <% } %>
        <% if (php.boxBackBackgroundType === 'solid' || !php.boxBackBackground) { %>
            <% if (php.boxBackUseGradient) { %>
                <div class="background-color" style="background: linear-gradient(<%= php.boxBackGradientDegrees || 180 %>deg, <%= php.boxBackBackgroundColor || '#ffffff' %> <%= php.boxBackGradientPosition || 50 %>%, <%= php.boxBackGradientColor || '#ffffff' %> 100%);"></div>
            <% } else { %>
                <div class="background-color" style="background-color: <%= php.boxBackBackgroundColor || '#ffffff' %>;"></div>
            <% } %>
        <% } %>
        <% if (php.boxBackBackgroundType === 'image' && php.boxBackBackground && php.boxBackUseGradient) { %>
            <div class="background-color" style="background: linear-gradient(<%= php.boxBackGradientDegrees || 180 %>deg, <%= php.boxBackBackgroundColor || '#ffffff' %> <%= php.boxBackGradientPosition || 50 %>%, <%= php.boxBackGradientColor || '#ffffff' %> 100%); opacity: 0.5;"></div>
        <% } %>
    </div>
    <div class="content">
        <% if (php.boxBackText) { %>
            <div class="back-text" style="color: <%= php.boxBackFontColor || '#000000' %>;"><%= php.boxBackText %></div>
        <% } %>
    </div>
</div>
<% } %>
</body>
</html>
