{
  "id": "cannock",
  "name": "Cannock Hits",
  "version": 8,
  "showMusicalNotes": false,
  "showRecord": false,
  "showEqualizer": true,
  "cacheTTL": 86400,
  "cssVariables": {
    "--app-background": "linear-gradient(135deg, #363158, #2e2a4d, #24213e)",
    "--app-text-color": "#ffffff",
    "--app-text-shadow": "1px 1px 3px rgba(0, 0, 0, 0.35)",
    "--app-button-background": "rgba(255, 255, 255, 0.14)",
    "--app-button-text-color": "#ffffff",
    "--app-button-background-hover": "rgba(255, 255, 255, 0.22)",
    "--app-button-background-activated": "rgba(255, 255, 255, 0.3)",
    "--app-button-background-disabled": "rgba(255, 255, 255, 0.07)",
    "--app-button-text-color-disabled": "rgba(255, 255, 255, 0.4)",
    "--app-choice-block-background": "rgba(255, 255, 255, 0.1)",
    "--app-choice-block-background-hover": "rgba(255, 255, 255, 0.18)",
    "--app-choice-block-background-active": "rgba(255, 255, 255, 0.26)",
    "--app-choice-block-background-selected": "rgba(184, 179, 232, 0.25)",
    "--app-choice-block-border-selected": "#b8b3e8",
    "--app-choice-block-text-color": "#ffffff",
    "--app-musical-note-color": "rgba(184, 179, 232, 0.75)",
    "--app-musical-note-shadow": "0 0 8px rgba(139, 133, 209, 0.5)",
    "--app-equalizer-color": "#f2d985",
    "--app-equalizer-offset-y": "120px",
    "--app-camera-icon-color": "#aebde8",
    "--app-camera-icon-offset-y": "20px",
    "--app-tap-text-color": "#aebde8",
    "--app-get-more-cards-text-color": "#aebde8",
    "--app-footer-text-color": "#aebde8",
    "--app-modal-header-background": "#1f1c36",
    "--app-modal-header-text-color": "#ffffff",
    "--app-modal-content-background": "linear-gradient(135deg, #363158, #2e2a4d)",
    "--app-modal-content-text-color": "#ffffff",
    "--app-modal-link-color": "#b8b3e8",
    "--app-scanner-guide-color": "#b8b3e8",
    "--app-flash-button-background-active": "rgba(184, 179, 232, 0.55)",
    "--app-logo-filter": "none",
    "--app-vinyl-gradient": "radial-gradient(circle at 30% 30%, #4a4578 40%, #2e2a4d 70%, #1a172f 100%)",
    "--app-vinyl-border": "#b8b3e8",
    "--app-vinyl-center-background": "#5b56a0",
    "--app-vinyl-center-border": "#1a172f"
  },
  "assets": {
    "logo": null,
    "background": null
  },
  "fonts": {
    "family": "Poppins, system-ui, -apple-system, sans-serif",
    "url": "https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap"
  },
  "helpText": "<h2>Welcome to Cannock Hits!</h2><p>Scan, listen and guess — let the music flow.</p><h3>How to play</h3><ol><li><strong>Pick a card</strong> from your Cannock Hits deck.</li><li><strong>Scan the QR code</strong> with your camera.</li><li><strong>Listen</strong> as the track starts playing automatically.</li><li><strong>Guess the song</strong> — title, artist or year.</li><li><strong>Share the memory</strong> behind it with your friends.</li></ol><p style='text-align: center; margin-top: 24px;'><em>Let the music flow.</em></p>"
}
