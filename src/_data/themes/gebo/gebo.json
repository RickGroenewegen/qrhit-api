{
  "id": "gebo",
  "name": "Gebotours",
  "version": 5,
  "showMusicalNotes": true,
  "showRecord": true,
  "showEqualizer": true,
  "cacheTTL": 86400,
  "cssVariables": {
    "--app-background": "radial-gradient(circle at 50% 18%, #fae1ba 0%, #fabb85 45%, #f7944a 100%)",
    "--app-text-color": "#ffffff",
    "--app-text-shadow": "0 1px 3px rgba(111, 42, 55, 0.45)",
    "--app-button-background": "#b7495b",
    "--app-button-text-color": "#ffffff",
    "--app-button-background-hover": "#c86879",
    "--app-button-background-activated": "#8f3848",
    "--app-button-background-disabled": "rgba(183, 73, 91, 0.18)",
    "--app-button-text-color-disabled": "rgba(183, 73, 91, 0.45)",
    "--app-choice-block-background": "rgba(183, 73, 91, 0.10)",
    "--app-choice-block-background-hover": "rgba(183, 73, 91, 0.18)",
    "--app-choice-block-background-active": "rgba(183, 73, 91, 0.26)",
    "--app-choice-block-background-selected": "rgba(171, 3, 61, 0.18)",
    "--app-choice-block-border-selected": "#ab033d",
    "--app-choice-block-text-color": "#b7495b",
    "--app-musical-note-color": "rgba(183, 73, 91, 0.55)",
    "--app-musical-note-shadow": "0 0 8px rgba(171, 3, 61, 0.40)",
    "--app-equalizer-color": "#ab033d",
    "--app-camera-icon-color": "#ffffff",
    "--app-tap-text-color": "#b7495b",
    "--app-get-more-cards-text-color": "#b7495b",
    "--app-footer-text-color": "#b7495b",
    "--app-modal-header-background": "#b7495b",
    "--app-modal-header-text-color": "#ffffff",
    "--app-modal-content-background": "linear-gradient(135deg, #fabb85, #f7944a)",
    "--app-modal-content-text-color": "#b7495b",
    "--app-modal-link-color": "#ab033d",
    "--app-scanner-guide-color": "#ffffff",
    "--app-flash-button-background-active": "rgba(255, 255, 255, 0.55)",
    "--app-logo-filter": "none",
    "--app-vinyl-gradient": "radial-gradient(circle at 30% 30%, #c86879 40%, #b7495b 70%, #6f2a37 100%)",
    "--app-vinyl-border": "#fae1ba",
    "--app-vinyl-center-background": "#ab033d",
    "--app-vinyl-center-border": "#6f2a37"
  },
  "assets": {
    "logo": null,
    "background": null
  },
  "fonts": {
    "family": "Poppins, system-ui, -apple-system, sans-serif",
    "url": "https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap"
  },
  "helpText": "<h2>Welcome to Gebotours!</h2><p>Scan, listen and name the track before anyone else gets there.</p><h3>How to play</h3><ol><li><strong>Pick a card</strong> from your Gebotours deck.</li><li><strong>Scan the QR code</strong> with your camera.</li><li><strong>Listen</strong> as the track starts playing automatically.</li><li><strong>Guess the song</strong> by title, artist or year.</li><li><strong>Share the memory</strong> and the journey behind the music.</li></ol><p style='text-align: center; margin-top: 24px;'><em>Let the music take you there.</em></p>"
}
