<!DOCTYPE html>
<html lang="en" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
    <meta charset="utf-8">
    <meta name="x-apple-disable-message-reformatting">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="format-detection" content="telephone=no, date=no, address=no, email=no">
    <title>{{ translations.boxInstructionsMailSubject }}</title>
    <!--[if mso]>
    <xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml>
    <style>
      td,th,div,p,a,h1,h2,h3,h4,h5,h6 {font-family: "Segoe UI", sans-serif; mso-line-height-rule: exactly;}
    </style>
    <![endif]-->
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Lato:wght@400;700&display=swap');
    </style>
</head>
<body style="margin: 0; padding: 0; width: 100%; word-break: break-word; -webkit-font-smoothing: antialiased; background-color: #f8fafc;">
    <div style="display: none;">{{ translations.boxInstructionsPreheader }}</div>
    <div role="article" aria-roledescription="email" aria-label="{{ productName }} Gift Box Instructions" lang="en" style="font-family: 'Lato', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background-color: #f8fafc;">
        <table style="width: 100%; font-family: 'Lato', sans-serif;" cellpadding="0" cellspacing="0" role="presentation">
            <tr>
                <td align="center" style="padding: 24px;">
                    <table class="container" style="width: 100%; max-width: 600px; background-color: #ffffff; border-radius: 8px; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);" cellpadding="0" cellspacing="0" role="presentation">
                        <tr>
                            <td style="padding: 24px;">
                                <!-- Logo -->
                                <table style="width: 100%;" cellpadding="0" cellspacing="0" role="presentation">
                                    <tr>
                                        <td align="center" style="padding-bottom: 24px;">
                                            <img src="cid:logo" alt="{{ productName }} Logo" style="max-width: 200px; height: auto;">
                                        </td>
                                    </tr>
                                </table>
                                <!-- Title -->
                                <table style="width: 100%;" cellpadding="0" cellspacing="0" role="presentation">
                                    <tr>
                                        <td align="center" style="padding-bottom: 16px;">
                                            <h1 style="margin: 0; font-size: 24px; line-height: 32px; font-weight: bold; color: #1a202c;">{{ translations.boxInstructionsTitle }}</h1>
                                        </td>
                                    </tr>
                                </table>
                                <!-- Content -->
                                <table style="width: 100%;" cellpadding="0" cellspacing="0" role="presentation">
                                    <tr>
                                        <td>
                                            <p style="margin: 0 0 24px; font-size: 16px; line-height: 24px; color: #4a5568;">{{ payment.fullname }},</p>
                                            <p style="margin: 0 0 24px; font-size: 16px; line-height: 24px; color: #4a5568;">{{ translations.boxInstructionsIntro }} <strong style="color: #1a202c;">{{ translations.boxInstructionsNoGlue }}</strong></p>
                                            <p style="margin: 0 0 16px; font-size: 16px; line-height: 24px; color: #4a5568;">{{ translations.boxInstructionsWatch }}</p>
                                        </td>
                                    </tr>
                                </table>
                                <!-- Video card -->
                                <table style="width: 100%;" cellpadding="0" cellspacing="0" role="presentation">
                                    <tr>
                                        <td align="center" style="padding-bottom: 24px;">
                                            <table style="width: 100%; max-width: 480px;" cellpadding="0" cellspacing="0" role="presentation">
                                                <tr>
                                                    <td style="border-radius: 12px; overflow: hidden; border: 1px solid #e2e8f0;">
                                                        <a href="{{ videoLink }}" target="_blank" style="display: block; text-decoration: none;">
                                                            <img src="{{ videoThumbnail }}" alt="{{ translations.boxInstructionsVideoAlt }}" width="480" style="width: 100%; max-width: 480px; height: auto; display: block; border: 0;">
                                                        </a>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td align="center" style="padding-top: 16px;">
                                                        <a href="{{ videoLink }}" target="_blank" style="background-color: #4299e1; border: solid 1px #4299e1; border-radius: 5px; box-sizing: border-box; color: #ffffff; cursor: pointer; display: inline-block; font-size: 16px; font-weight: bold; margin: 0; padding: 12px 25px; text-decoration: none;">&#9654;&nbsp;&nbsp;{{ translations.boxInstructionsWatchButton }}</a>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>
                                </table>
                                <!-- Steps -->
                                <table style="width: 100%; background-color: #ebf8ff; border-radius: 8px;" cellpadding="0" cellspacing="0" role="presentation">
                                    <tr>
                                        <td style="padding: 20px 24px;">
                                            <table cellpadding="0" cellspacing="0" role="presentation">
                                                <tr>
                                                    <td valign="top" style="padding: 6px 12px 6px 0;">
                                                        <table cellpadding="0" cellspacing="0" role="presentation"><tr><td align="center" style="width: 26px; height: 26px; border-radius: 13px; background-color: #4299e1; color: #ffffff; font-size: 14px; font-weight: bold; line-height: 26px;">1</td></tr></table>
                                                    </td>
                                                    <td valign="middle" style="padding: 6px 0; font-size: 15px; line-height: 22px; color: #4a5568;">{{ translations.boxInstructionsStep1 }}</td>
                                                </tr>
                                                <tr>
                                                    <td valign="top" style="padding: 6px 12px 6px 0;">
                                                        <table cellpadding="0" cellspacing="0" role="presentation"><tr><td align="center" style="width: 26px; height: 26px; border-radius: 13px; background-color: #4299e1; color: #ffffff; font-size: 14px; font-weight: bold; line-height: 26px;">2</td></tr></table>
                                                    </td>
                                                    <td valign="middle" style="padding: 6px 0; font-size: 15px; line-height: 22px; color: #4a5568;">{{ translations.boxInstructionsStep2 }}</td>
                                                </tr>
                                                <tr>
                                                    <td valign="top" style="padding: 6px 12px 6px 0;">
                                                        <table cellpadding="0" cellspacing="0" role="presentation"><tr><td align="center" style="width: 26px; height: 26px; border-radius: 13px; background-color: #4299e1; color: #ffffff; font-size: 14px; font-weight: bold; line-height: 26px;">3</td></tr></table>
                                                    </td>
                                                    <td valign="middle" style="padding: 6px 0; font-size: 15px; line-height: 22px; color: #4a5568;">{{ translations.boxInstructionsStep3 }}</td>
                                                </tr>
                                                <tr>
                                                    <td valign="top" style="padding: 6px 12px 6px 0;">
                                                        <table cellpadding="0" cellspacing="0" role="presentation"><tr><td align="center" style="width: 26px; height: 26px; border-radius: 13px; background-color: #4299e1; color: #ffffff; font-size: 14px; font-weight: bold; line-height: 26px;">4</td></tr></table>
                                                    </td>
                                                    <td valign="middle" style="padding: 6px 0; font-size: 15px; line-height: 22px; color: #4a5568;">{{ translations.boxInstructionsStep4 }}</td>
                                                </tr>
                                                <tr>
                                                    <td valign="top" style="padding: 6px 12px 6px 0;">
                                                        <table cellpadding="0" cellspacing="0" role="presentation"><tr><td align="center" style="width: 26px; height: 26px; border-radius: 13px; background-color: #4299e1; color: #ffffff; font-size: 14px; font-weight: bold; line-height: 26px;">5</td></tr></table>
                                                    </td>
                                                    <td valign="middle" style="padding: 6px 0; font-size: 15px; line-height: 22px; color: #4a5568;">{{ translations.boxInstructionsStep5 }}</td>
                                                </tr>
                                                <tr>
                                                    <td valign="top" style="padding: 6px 12px 6px 0;">
                                                        <table cellpadding="0" cellspacing="0" role="presentation"><tr><td align="center" style="width: 26px; height: 26px; border-radius: 13px; background-color: #4299e1; color: #ffffff; font-size: 14px; font-weight: bold; line-height: 26px;">6</td></tr></table>
                                                    </td>
                                                    <td valign="middle" style="padding: 6px 0; font-size: 15px; line-height: 22px; color: #4a5568;">{{ translations.boxInstructionsStep6 }}</td>
                                                </tr>
                                                <tr>
                                                    <td valign="top" style="padding: 6px 12px 6px 0;">
                                                        <table cellpadding="0" cellspacing="0" role="presentation"><tr><td align="center" style="width: 26px; height: 26px; border-radius: 13px; background-color: #4299e1; color: #ffffff; font-size: 14px; font-weight: bold; line-height: 26px;">7</td></tr></table>
                                                    </td>
                                                    <td valign="middle" style="padding: 6px 0; font-size: 15px; line-height: 22px; color: #4a5568;">{{ translations.boxInstructionsStep7 }}</td>
                                                </tr>
                                                <tr>
                                                    <td valign="top" style="padding: 6px 12px 6px 0;">
                                                        <table cellpadding="0" cellspacing="0" role="presentation"><tr><td align="center" style="width: 26px; height: 26px; border-radius: 13px; background-color: #4299e1; color: #ffffff; font-size: 14px; font-weight: bold; line-height: 26px;">8</td></tr></table>
                                                    </td>
                                                    <td valign="middle" style="padding: 6px 0; font-size: 15px; line-height: 22px; color: #4a5568;">{{ translations.boxInstructionsStep8 }}</td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>
                                </table>
                                <!-- Outro -->
                                <table style="width: 100%;" cellpadding="0" cellspacing="0" role="presentation">
                                    <tr>
                                        <td style="padding-top: 24px;">
                                            <p style="margin: 0 0 24px; font-size: 16px; line-height: 24px; color: #4a5568;">{{ translations.boxInstructionsMoreInfo }} <a href="{{ giftBoxLink }}" target="_blank" style="color: #4299e1; text-decoration: underline;">{{ translations.boxInstructionsPageLink }}</a></p>
                                            <p style="margin: 0; font-size: 16px; line-height: 24px; color: #4a5568;">{{ translations.thankYou }}</p>
                                        </td>
                                    </tr>
                                </table>
                                <!-- Closing -->
                                <table style="width: 100%;" cellpadding="0" cellspacing="0" role="presentation">
                                    <tr>
                                        <td style="padding-top: 32px;">
                                            <p style="margin: 0; font-size: 16px; line-height: 24px; color: #4a5568;">
                                                {{ translations.greetings }},<br>
                                                {{ productName }}
                                            </p>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>
                    <!-- Footer -->
                    <table style="width: 100%; max-width: 600px;" cellpadding="0" cellspacing="0" role="presentation">
                        <tr>
                            <td style="padding: 24px; text-align: center; font-size: 12px; color: #718096;">
                                <p style="margin: 0;">&copy; {{ currentYear }} {{ productName }}. All rights reserved.</p>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </div>
</body>
</html>
